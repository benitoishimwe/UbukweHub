// Prisma schema — maps to existing Supabase PostgreSQL tables
// Generated for Plani platform multi-tenant architecture

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  tenantId               String    @id @default(uuid()) @map("tenant_id") @db.Uuid
  name                   String
  slug                   String    @unique
  subdomain              String?   @unique
  logoUrl                String?   @map("logo_url")
  primaryColor           String?   @map("primary_color")
  subscriptionTier       String    @default("free") @map("subscription_tier")
  subscriptionStatus     String    @default("active") @map("subscription_status")
  stripeCustomerId       String?   @map("stripe_customer_id")
  stripeSubscriptionId   String?   @map("stripe_subscription_id")
  paystackSubscriptionCode String? @map("paystack_subscription_code")
  trialEndsAt            DateTime? @map("trial_ends_at")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  users              User[]
  events             Event[]
  eventTasks         EventTask[]
  subscriptions      Subscription[]
  vendors            Vendor[]
  vendorProfiles     VendorProfile[]
  weddingPlans       WeddingPlan[]
  albums             Album[]
  saveTheDateDesigns SaveTheDateDesign[]
  inventory          InventoryItem[]
  transactions       Transaction[]
  shifts             Shift[]
  invitations        TenantInvitation[]
  messages           Message[]
  notifications      Notification[]
  apiKeys            ApiKey[]
  testAccounts       TestAccount[]

  @@map("tenants")
}

model User {
  userId       String    @id @default(uuid()) @map("user_id") @db.Uuid
  email        String    @unique
  name         String
  role         String    @default("client")
  passwordHash String?   @map("password_hash")
  googleId     String?   @map("google_id")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  mfaSecret    String?   @map("mfa_secret")
  skills       Json?
  certifications Json?
  availability String?
  tenantId     String?   @map("tenant_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant             Tenant?            @relation(fields: [tenantId], references: [tenantId])
  subscriptions      Subscription[]
  payments           Payment[]
  vendorReviews      VendorReview[]
  vendorFavorites    VendorFavorite[]
  vendorInquiries    VendorInquiry[]
  weddingPlans       WeddingPlan[]
  saveTheDateDesigns SaveTheDateDesign[]
  sessions           UserSession[]
  emailOtps          EmailOtp[]
  auditLogs          AuditLog[]
  invitationsSent    TenantInvitation[] @relation("InvitedBy")
  messagesSent       Message[]          @relation("MessageSender")
  vendorProfile      Vendor?            @relation("VendorUser")
  assignedTasks      EventTask[]        @relation("TaskAssignee")
  notifications      Notification[]
  apiKeysCreated       ApiKey[]             @relation("ApiKeyCreator")
  testAccountsOwned    TestAccount[]        @relation("TestAccountUser")
  testAccountsCreated  TestAccount[]        @relation("TestAccountCreator")
  supportTickets       SupportTicket[]      @relation("TicketUser")
  assignedTickets      SupportTicket[]      @relation("TicketAssignee")
  chatbotConversations ChatbotConversation[]
  channelMessages      ChannelMessage[]     @relation("ChannelMessageSender")
  channelReadStatuses  ChannelReadStatus[]

  @@map("users")
}

model Event {
  eventId         String    @id @default(uuid()) @map("event_id") @db.Uuid
  tenantId        String?   @map("tenant_id") @db.Uuid
  name            String
  eventDate       String?   @map("event_date")
  venue           String?
  clientId        String?   @map("client_id") @db.Uuid
  clientName      String?   @map("client_name")
  staffIds        Json?     @map("staff_ids")
  vendorIds       Json?     @map("vendor_ids")
  status          String    @default("planning")
  budget          Decimal?  @db.Decimal(12, 2)
  guestCount      Int?      @map("guest_count")
  greatnessScore  Int?      @map("greatness_score")
  notes           String?
  eventTypeSlug   String?   @map("event_type_slug")
  checklist       Json?
  timeline        Json?
  seatingPlan     Json?     @map("seating_plan")
  guestList                    Json?     @map("guest_list")
  budgetBreakdown              Json?     @map("budget_breakdown")
  createdBy                    String?   @map("created_by") @db.Uuid
  guestCheckinEnabled          Boolean   @default(false) @map("guest_checkin_enabled")
  guestCheckinOtpExpiryMinutes Int       @default(10) @map("guest_checkin_otp_expiry_minutes")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  tenant               Tenant?               @relation(fields: [tenantId], references: [tenantId])
  tasks                EventTask[]
  weddingPlans         WeddingPlan[]
  albums               Album[]
  saveTheDateDesigns   SaveTheDateDesign[]
  transactions         Transaction[]
  shifts               Shift[]
  vendorReviews        VendorReview[]
  vendorInquiries      VendorInquiry[]
  messages             Message[]
  guestCheckinAttempts GuestCheckinAttempt[]
  guestCheckins        GuestCheckin[]
  channelMessages      ChannelMessage[]
  connectedVendors     EventVendor[]

  @@map("events")
}

model EventType {
  eventTypeId       String   @id @default(uuid()) @map("event_type_id") @db.Uuid
  slug              String   @unique
  name              String
  description       String?
  icon              String?
  checklistTemplate Json?    @map("checklist_template")
  timelineTemplate  Json?    @map("timeline_template")
  budgetCategories  Json?    @map("budget_categories")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("event_types")
}

model EventTask {
  taskId      String    @id @default(uuid()) @map("task_id") @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  title       String
  description String?
  category    String?
  dueDate     DateTime? @map("due_date")
  assignedTo  String?   @map("assigned_to") @db.Uuid
  assignedAt  DateTime? @map("assigned_at") @db.Timestamptz
  status      String    @default("todo")
  priority    String    @default("medium")
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  event    Event  @relation(fields: [eventId], references: [eventId])
  tenant   Tenant @relation(fields: [tenantId], references: [tenantId])
  assignee User?  @relation("TaskAssignee", fields: [assignedTo], references: [userId])

  @@map("event_tasks")
}

model Subscription {
  subscriptionId        String    @id @default(uuid()) @map("subscription_id") @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  tenantId              String?   @map("tenant_id") @db.Uuid
  plan                  String    @default("free")
  status                String    @default("active")
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  paystackSubscriptionCode String? @map("paystack_subscription_code")
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  trialEndsAt           DateTime? @map("trial_ends_at")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [userId])
  tenant   Tenant?   @relation(fields: [tenantId], references: [tenantId])
  payments Payment[]

  @@map("subscriptions")
}

model SubscriptionFeature {
  featureId   String   @id @default(uuid()) @map("feature_id") @db.Uuid
  plan        String
  featureKey  String   @map("feature_key")
  isEnabled   Boolean  @map("is_enabled")
  limitValue  Int?     @map("limit_value")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("subscription_features")
}

model Payment {
  paymentId        String   @id @default(uuid()) @map("payment_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  subscriptionId   String   @map("subscription_id") @db.Uuid
  provider         String
  providerPaymentId String  @map("provider_payment_id")
  amount           Decimal  @db.Decimal(12, 2)
  currency         String
  status           String
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [userId])
  subscription Subscription @relation(fields: [subscriptionId], references: [subscriptionId])

  @@map("payments")
}

model Vendor {
  vendorId           String    @id @default(uuid()) @map("vendor_id") @db.Uuid
  tenantId           String?   @map("tenant_id") @db.Uuid
  userId             String?   @unique @map("user_id") @db.Uuid
  name               String
  category           String
  contactName        String?   @map("contact_name")
  email              String?
  phone              String?
  location           String?
  country            String?
  description        String?
  rating             Decimal   @default(0) @db.Decimal(3, 2)
  ratingCount        Int       @default(0) @map("rating_count")
  viewCount          Int       @default(0) @map("view_count")
  likeCount          Int       @default(0) @map("like_count")
  isVerified         Boolean   @default(false) @map("is_verified")
  isActive           Boolean   @default(true) @map("is_active")
  isPublic           Boolean   @default(false) @map("is_public")
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  approvedByAdmin    Boolean   @default(false) @map("approved_by_admin")
  approvedAt         DateTime? @map("approved_at")
  rejectedReason     String?   @map("rejected_reason")
  internalNotes      String?   @map("internal_notes")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant          Tenant?            @relation(fields: [tenantId], references: [tenantId])
  linkedUser      User?              @relation("VendorUser", fields: [userId], references: [userId])
  profile         VendorProfile?
  portfolio       VendorPortfolio[]
  reviews         VendorReview[]
  favorites       VendorFavorite[]
  inquiries       VendorInquiry[]
  onboarding      VendorOnboarding?
  analytics       VendorAnalytics[]
  connectedEvents EventVendor[]

  @@map("vendors")
}

model VendorProfile {
  profileId           String   @id @default(uuid()) @map("profile_id") @db.Uuid
  tenantId            String?  @map("tenant_id") @db.Uuid
  vendorId            String   @unique @map("vendor_id") @db.Uuid
  bio                 String?
  website             String?
  instagram           String?
  facebook            String?
  serviceAreas        Json?    @map("service_areas")
  priceMin            Decimal? @map("price_min") @db.Decimal(12, 2)
  priceMax            Decimal? @map("price_max") @db.Decimal(12, 2)
  currency            String   @default("RWF")
  packages            Json?
  availability        Json?
  tags                Json?
  isMarketplaceActive Boolean  @default(false) @map("is_marketplace_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [tenantId])
  vendor Vendor  @relation(fields: [vendorId], references: [vendorId])

  @@map("vendor_profiles")
}

model VendorPortfolio {
  portfolioId  String   @id @default(uuid()) @map("portfolio_id") @db.Uuid
  vendorId     String   @map("vendor_id") @db.Uuid
  imageUrl     String   @map("image_url")
  caption      String?
  eventType    String?  @map("event_type")
  displayOrder Int      @default(0) @map("display_order")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  vendor Vendor @relation(fields: [vendorId], references: [vendorId])

  @@map("vendor_portfolio")
}

model VendorReview {
  reviewId   String   @id @default(uuid()) @map("review_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventId    String?  @map("event_id") @db.Uuid
  rating     Int
  title      String?
  body       String?
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  vendor Vendor  @relation(fields: [vendorId], references: [vendorId])
  user   User    @relation(fields: [userId], references: [userId])
  event  Event?  @relation(fields: [eventId], references: [eventId])

  @@map("vendor_reviews")
}

model VendorFavorite {
  favoriteId String   @id @default(uuid()) @map("favorite_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [userId])
  vendor Vendor @relation(fields: [vendorId], references: [vendorId])

  @@unique([userId, vendorId])
  @@map("vendor_favorites")
}

model VendorInquiry {
  inquiryId  String    @id @default(uuid()) @map("inquiry_id") @db.Uuid
  vendorId   String    @map("vendor_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  eventId    String?   @map("event_id") @db.Uuid
  message    String?
  budget     Decimal?  @db.Decimal(12, 2)
  eventDate  DateTime? @map("event_date")
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  vendor Vendor  @relation(fields: [vendorId], references: [vendorId])
  user   User    @relation(fields: [userId], references: [userId])
  event  Event?  @relation(fields: [eventId], references: [eventId])

  @@map("vendor_inquiries")
}

model VendorOnboarding {
  vendorId               String    @id @map("vendor_id") @db.Uuid
  stepBio                Boolean   @default(false) @map("step_bio")
  stepPricing            Boolean   @default(false) @map("step_pricing")
  stepPhotos             Boolean   @default(false) @map("step_photos")
  stepMarketplaceConsent Boolean   @default(false) @map("step_marketplace_consent")
  completedAt            DateTime? @map("completed_at")

  vendor Vendor @relation(fields: [vendorId], references: [vendorId], onDelete: Cascade)

  @@map("vendor_onboarding")
}

model VendorAnalytics {
  analyticsId String   @id @default(uuid()) @map("analytics_id") @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  date        DateTime @db.Date
  views       Int      @default(0)
  likes       Int      @default(0)
  inquiries   Int      @default(0)

  vendor Vendor @relation(fields: [vendorId], references: [vendorId], onDelete: Cascade)

  @@unique([vendorId, date])
  @@map("vendor_analytics")
}

model WeddingPlan {
  planId          String    @id @default(uuid()) @map("plan_id") @db.Uuid
  tenantId        String?   @map("tenant_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  eventId         String?   @map("event_id") @db.Uuid
  weddingDate     DateTime? @map("wedding_date")
  theme           String?
  primaryColor    String?   @map("primary_color")
  secondaryColor  String?   @map("secondary_color")
  totalBudget     Decimal?  @map("total_budget") @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant?             @relation(fields: [tenantId], references: [tenantId])
  user         User                @relation(fields: [userId], references: [userId])
  event        Event?              @relation(fields: [eventId], references: [eventId])
  budgetItems  WeddingBudgetItem[]
  guests       WeddingGuest[]
  venues       WeddingVenue[]
  menuItems    WeddingMenuItem[]
  designAssets WeddingDesignAsset[]

  @@map("wedding_plans")
}

model WeddingBudgetItem {
  itemId        String    @id @default(uuid()) @map("item_id") @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  category      String
  description   String?
  estimatedCost Decimal?  @map("estimated_cost") @db.Decimal(12, 2)
  actualCost    Decimal?  @map("actual_cost") @db.Decimal(12, 2)
  vendorId      String?   @map("vendor_id") @db.Uuid
  status        String    @default("planned")
  dueDate       DateTime? @map("due_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  plan WeddingPlan @relation(fields: [planId], references: [planId])

  @@map("wedding_budget_items")
}

model WeddingGuest {
  guestId              String   @id @default(uuid()) @map("guest_id") @db.Uuid
  planId               String   @map("plan_id") @db.Uuid
  fullName             String   @map("full_name")
  email                String?
  phone                String?
  rsvpStatus           String   @default("pending") @map("rsvp_status")
  mealChoice           String?  @map("meal_choice")
  dietaryRestrictions  String?  @map("dietary_restrictions")
  tableNumber          Int?     @map("table_number")
  invitationSent       Boolean  @default(false) @map("invitation_sent")
  thankYouSent         Boolean  @default(false) @map("thank_you_sent")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  plan WeddingPlan @relation(fields: [planId], references: [planId])

  @@map("wedding_guests")
}

model WeddingVenue {
  venueId      String   @id @default(uuid()) @map("venue_id") @db.Uuid
  planId       String   @map("plan_id") @db.Uuid
  name         String
  address      String?
  contactName  String?  @map("contact_name")
  contactPhone String?  @map("contact_phone")
  capacity     Int?
  rentalFee    Decimal? @map("rental_fee") @db.Decimal(12, 2)
  includedItems String? @map("included_items")
  notes        String?
  isSelected   Boolean  @default(false) @map("is_selected")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plan WeddingPlan @relation(fields: [planId], references: [planId])

  @@map("wedding_venues")
}

model WeddingMenuItem {
  itemId        String   @id @default(uuid()) @map("item_id") @db.Uuid
  planId        String   @map("plan_id") @db.Uuid
  course        String?
  name          String
  description   String?
  dietaryInfo   String?  @map("dietary_info")
  isFinal       Boolean  @default(false) @map("is_final")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  plan WeddingPlan @relation(fields: [planId], references: [planId])

  @@map("wedding_menu_items")
}

model WeddingDesignAsset {
  assetId   String   @id @default(uuid()) @map("asset_id") @db.Uuid
  planId    String   @map("plan_id") @db.Uuid
  imageUrl  String   @map("image_url")
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  plan WeddingPlan @relation(fields: [planId], references: [planId])

  @@map("wedding_design_assets")
}

model Album {
  albumId       String   @id @default(uuid()) @map("album_id") @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  token         String   @unique @db.VarChar(255)
  title         String
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  maxFileSizeMb Int      @default(50) @map("max_file_size_mb")
  allowVideos   Boolean  @default(true) @map("allow_videos")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant?      @relation(fields: [tenantId], references: [tenantId])
  event  Event        @relation(fields: [eventId], references: [eventId])
  media  AlbumMedia[]

  @@map("albums")
}

model AlbumMedia {
  mediaId      String   @id @default(uuid()) @map("media_id") @db.Uuid
  albumId      String   @map("album_id") @db.Uuid
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  fileType     String   @map("file_type")
  mediaType    String   @default("image") @map("media_type")
  fileSize     BigInt   @map("file_size")
  fileUrl      String   @map("file_url")
  thumbnailUrl String?  @map("thumbnail_url")
  uploaderName String?  @map("uploader_name")
  isFavorite   Boolean  @default(false) @map("is_favorite")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  album Album @relation(fields: [albumId], references: [albumId])

  @@map("album_media")
}

model SaveTheDateDesign {
  designId         String   @id @default(uuid()) @map("design_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  eventId          String?  @map("event_id") @db.Uuid
  title            String
  templateId       String?  @map("template_id")
  textContent      Json?    @map("text_content")
  style            Json?
  uploadedPhoto    String?  @map("uploaded_photo") @db.Text
  generatedImageUrl String? @map("generated_image_url") @db.Text
  aiPromptUsed     String?  @map("ai_prompt_used")
  status           String   @default("draft")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [tenantId])
  user   User   @relation(fields: [userId], references: [userId])
  event  Event? @relation(fields: [eventId], references: [eventId])

  @@map("save_the_date_designs")
}

model InventoryItem {
  itemId        String   @id @default(uuid()) @map("item_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  category      String?
  qrCode        String?  @unique @map("qr_code") @db.VarChar(255)
  barcode       String?
  quantity      Int      @default(0)
  available     Int      @default(0)
  rented        Int      @default(0)
  washing       Int      @default(0)
  condition     String   @default("good")
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(12, 2)
  rentalPrice   Decimal? @map("rental_price") @db.Decimal(12, 2)
  photos        Json?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [tenantId])
  transactions Transaction[]

  @@map("inventory")
}

model Transaction {
  transactionId String    @id @default(uuid()) @map("transaction_id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  type          String
  itemId        String?   @map("item_id") @db.Uuid
  itemName      String?   @map("item_name")
  eventId       String?   @map("event_id") @db.Uuid
  eventName     String?   @map("event_name")
  staffId       String?   @map("staff_id") @db.Uuid
  staffName     String?   @map("staff_name")
  quantity      Int?
  photo         String?
  returnDate    DateTime? @map("return_date")
  daysToReturn  Int?      @map("days_to_return")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant         @relation(fields: [tenantId], references: [tenantId])
  item   InventoryItem? @relation(fields: [itemId], references: [itemId])
  event  Event?         @relation(fields: [eventId], references: [eventId])

  @@map("transactions")
}

model Shift {
  shiftId   String   @id @default(uuid()) @map("shift_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  eventId   String?  @map("event_id") @db.Uuid
  staffId   String?  @map("staff_id") @db.Uuid
  staffName String?  @map("staff_name")
  role      String?
  date      DateTime?
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  status    String   @default("scheduled")
  tasks     Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [tenantId])
  event  Event? @relation(fields: [eventId], references: [eventId])

  @@map("shifts")
}

model UserSession {
  sessionId    String   @id @default(uuid()) @map("session_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(512)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("user_sessions")
}

model TenantInvitation {
  invitationId String    @id @default(uuid()) @map("invitation_id") @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String
  role         String
  type         String    @default("team")
  token        String    @unique @db.VarChar(512)
  invitedBy    String?   @map("invited_by") @db.Uuid
  acceptedAt   DateTime? @map("accepted_at")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant    Tenant @relation(fields: [tenantId], references: [tenantId])
  inviter   User?  @relation("InvitedBy", fields: [invitedBy], references: [userId])

  @@map("tenant_invitations")
}

model EventVendor {
  eventId     String   @map("event_id") @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  connectedAt DateTime @default(now()) @map("connected_at") @db.Timestamptz

  event  Event  @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [vendorId], onDelete: Cascade)

  @@id([eventId, vendorId])
  @@map("event_vendors")
}

model EmailOtp {
  otpId     String   @id @default(uuid()) @map("otp_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("email_otps")
}

model AuditLog {
  logId      String   @id @default(uuid()) @map("log_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  userEmail  String?  @map("user_email")
  action     String
  resource   String?
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [userId])

  @@map("audit_logs")
}

model Message {
  messageId   String   @id @default(uuid()) @map("message_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  eventId     String?  @map("event_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  senderName  String   @map("sender_name")
  senderRole  String   @map("sender_role")
  recipientId String?  @map("recipient_id")
  content     String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [tenantId])
  event  Event? @relation(fields: [eventId], references: [eventId])
  sender User   @relation("MessageSender", fields: [senderId], references: [userId])

  @@map("messages")
}

model Notification {
  notificationId String   @id @default(uuid()) @map("notification_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  type           String
  title          String
  body           String?
  resourceId     String?  @map("resource_id") @db.Uuid
  resourceType   String?  @map("resource_type")
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [userId])
  tenant Tenant @relation(fields: [tenantId], references: [tenantId])

  @@map("notifications")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────
model ApiKey {
  keyId       String    @id @default(uuid()) @map("key_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  createdBy   String    @map("created_by") @db.Uuid
  name        String
  prefix      String
  keyHash     String    @unique @map("key_hash")
  scopes      String[]  @default([])
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [tenantId])
  creator User  @relation("ApiKeyCreator", fields: [createdBy], references: [userId])

  @@map("api_keys")
}

// ─── Test Accounts ────────────────────────────────────────────────────────────
model TestAccount {
  testAccountId String    @id @default(uuid()) @map("test_account_id") @db.Uuid
  email         String
  tenantId      String    @map("tenant_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  createdBy     String?   @map("created_by") @db.Uuid
  plan          String    @default("pro")
  expiresAt     DateTime  @map("expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [tenantId])
  user    User   @relation("TestAccountUser", fields: [userId], references: [userId])
  creator User?  @relation("TestAccountCreator", fields: [createdBy], references: [userId])

  @@map("test_accounts")
}

// ─── Guest Check-in ───────────────────────────────────────────────────────────
model GuestCheckinAttempt {
  attemptId      String    @id @default(uuid()) @map("attempt_id") @db.Uuid
  eventId        String    @map("event_id") @db.Uuid
  email          String
  guestName      String?   @map("guest_name")
  otpCode        String?   @map("otp_code")
  otpExpiresAt   DateTime? @map("otp_expires_at") @db.Timestamptz
  verifiedAt     DateTime? @map("verified_at") @db.Timestamptz
  status         String    @default("pending")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, email])
  @@map("guest_checkin_attempts")
}

model GuestCheckin {
  checkinId   String   @id @default(uuid()) @map("checkin_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  email       String
  guestName   String?  @map("guest_name")
  checkedInAt DateTime @default(now()) @map("checked_in_at") @db.Timestamptz
  ipAddress   String?  @map("ip_address")

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("guest_checkins")
}

// ─── Support System ───────────────────────────────────────────────────────────
model SupportTicket {
  ticketId   String   @id @default(uuid()) @map("ticket_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  email      String
  subject    String
  message    String
  status     String   @default("open")
  priority   String   @default("normal")
  assignedTo String?  @map("assigned_to") @db.Uuid
  resolution String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user            User?            @relation("TicketUser", fields: [userId], references: [userId])
  assignee        User?            @relation("TicketAssignee", fields: [assignedTo], references: [userId])
  supportMessages SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  messageId  String   @id @default(uuid()) @map("message_id") @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  senderType String   @map("sender_type")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [ticketId], onDelete: Cascade)

  @@map("support_messages")
}

model ChatbotConversation {
  conversationId String   @id @default(uuid()) @map("conversation_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  sessionToken   String?  @map("session_token")
  createdAt      DateTime @default(now()) @map("created_at")

  user     User?            @relation(fields: [userId], references: [userId])
  messages ChatbotMessage[]

  @@map("chatbot_conversations")
}

model ChatbotMessage {
  messageId      String   @id @default(uuid()) @map("message_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatbotConversation @relation(fields: [conversationId], references: [conversationId], onDelete: Cascade)

  @@map("chatbot_messages")
}

// ─── Event Chat ───────────────────────────────────────────────────────────────

model ChannelMessage {
  messageId       String    @id @default(uuid()) @map("message_id") @db.Uuid
  eventId         String    @map("event_id") @db.Uuid
  senderId        String    @map("sender_id") @db.Uuid
  senderName      String    @map("sender_name")
  senderRole      String    @map("sender_role")
  content         String?
  attachments     Json?
  parentMessageId String?   @map("parent_message_id") @db.Uuid
  isPinned        Boolean   @default(false) @map("is_pinned")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  event   Event            @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  sender  User             @relation("ChannelMessageSender", fields: [senderId], references: [userId])
  parent  ChannelMessage?  @relation("MessageReplies", fields: [parentMessageId], references: [messageId], onDelete: NoAction, onUpdate: NoAction)
  replies ChannelMessage[] @relation("MessageReplies")

  @@map("channel_messages")
}

model ChannelReadStatus {
  userId     String   @map("user_id") @db.Uuid
  channelId  String   @map("channel_id") @db.Uuid
  lastReadAt DateTime @default(now()) @map("last_read_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, channelId])
  @@map("channel_read_status")
}
